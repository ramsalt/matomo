apiVersion: v1
kind: Config
clusters:
- cluster:
    certificate-authority-data: 
    server: https://xo0k0c.c1.gra7.k8s.ovh.net
  name: Matomo
users:
- name: circle-ci
  user:
    exec:
      apiVersion: client.authentication.k8s.io/v1
      command: /bin/echo
      args:
      - $CIRCLE_OIDC_TOKEN
      interactiveMode: IfAvailable
      provideClusterInfo: false
contexts:
- context:
    cluster: Matomo
    user: circle-ci
  name: circle-ci-Matomo
current-context: circle-ci-Matomo
